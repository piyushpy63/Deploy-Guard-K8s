{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deploy Guard Chart Values Schema",
  "type": "object",
  "required": ["watchNamespaces", "prometheus", "loki"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "Never", "IfNotPresent"] }
      }
    },
    "watchNamespaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "labelSelector": { "type": "string" },
    "interval": { "type": "integer", "minimum": 5 },
    "watchDuration": {
      "type": "string",
      "pattern": "^[0-9]+[smh]$"
    },
    "dryRun": { "type": "boolean" },
    "prometheus": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "pattern": "^https?://" }
      }
    },
    "loki": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "pattern": "^https?://" }
      }
    },
    "slack": {
      "type": "object",
      "properties": {
        "existingSecretName": { "type": "string" },
        "webhookUrl": { "type": "string" }
      }
    },
    "persistence": {
      "type": "object",
      "required": ["enabled", "size", "baselinePath", "auditDB"],
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "size": { "type": "string" },
        "baselinePath": { "type": "string" },
        "auditDB": { "type": "string" }
      }
    }
  }
}
